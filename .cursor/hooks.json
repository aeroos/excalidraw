{
  "version": 1,
  "hooks": {
    "beforeReadFile": [
      {
        "command": "node .cursor/hooks/protect-secrets.js",
        "failClosed": true
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/protect-shell.js",
        "failClosed": true
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/a11y-check.js"
      }
    ]
  }
}
